# ==========================================
# CartoonDex - Configurações de Ignore do Git
# ==========================================

# Arquivo de configuração local com TOKENS e SENHAS (CRÍTICO)
.env

# Pastas e arquivos gerados automaticamente pelo Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Arquivos do ambiente virtual do Python (caso utilize no futuro)
venv/
.venv/
env/

# Arquivos temporários de sistemas operacionais
.DS_Store
Thumbs.db

# Opcional: Descomente a linha abaixo se não quiser enviar arquivos de dados locais (.json)
# data/*.json